# ============================================================
# ERPNext v15 + HRMS + Healthcare - Docker Environment Config
# ============================================================
# IMPORTANT: Copy this file to .env.local and fill real passwords
# Never commit .env.local to Git

# --- Frappe / ERPNext ---
FRAPPE_VERSION=version-15
ERPNEXT_VERSION=version-15

# --- Site ---
SITE_NAME=site1.local

# --- MariaDB ---
DB_PASSWORD=changeme_db_password
MARIADB_ROOT_PASSWORD=changeme_root_password

# --- Admin ---
ADMIN_PASSWORD=changeme_admin_password

# --- Redis ---
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# --- Custom Image ---
CUSTOM_IMAGE=frappe-erpnext-custom
CUSTOM_TAG=v15
